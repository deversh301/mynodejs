{
  "family": "ecr-to-ec2-task-definition",
  "networkMode": "bridge",
  "executionRoleArn": "arn:aws:iam::026296209230:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "ecr-to-ecs-container",
      "image": "IMAGE_URI",
      "cpu": 256,
      "memory": 512,
      "essential": true,
     "portMappings": [
        {
            "containerPort": 5000,
            "hostPort": 0,
            "protocol": "tcp"
        }
    ]
    }
  ]
}